#!/bin/sh
python - "$1" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
if not path.exists():
    print("找不到提交信息文件")
    sys.exit(1)

lines = path.read_text(encoding="utf-8", errors="ignore").splitlines()
first_line = lines[0] if lines else ""

pattern = r"^(feat|fix|docs|style|refactor|perf|test|chore)(\([a-z]+\))?: .+"
if not re.match(pattern, first_line):
    print("提交信息需要符合 Conventional Commits，例如：docs: 补充开源说明")
    sys.exit(1)

subject = first_line.split(": ", 1)[1] if ": " in first_line else ""
if not re.search(r"[\u4e00-\u9fff]", subject):
    print("提交主题需要包含简体中文")
    sys.exit(1)

if subject.endswith(("。", ".", "!", "？", "?")):
    print("提交主题末尾不要使用句号或感叹号")
    sys.exit(1)
PY
